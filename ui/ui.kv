#:kivy 2.0.0

ScreenManager:
    SearchScreen:
    DetailsScreen:
    LibraryScreen:


<SearchScreen>:
    name: "search"

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        # Поисковая строка
        TextInput:
            id: search_input
            hint_text: "Enter movie name"
            size_hint_y: None
            height: 40

        BoxLayout:
            size_hint_y: None
            height: 40
            spacing: 10

            Button:
                text: "Search"
                on_press: root.search_movie()

            Button:
                text: "Refresh Recommendations"
                on_press: root.refresh_recommendations()

            Button:
                text: "Library"
                on_press: root.open_library()

        # Список результатов и рекомендаций
        ScrollView:
            GridLayout:
                id: results_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                row_default_height: 40
                row_force_default: True


<DetailsScreen>:
    name: "details"

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Label:
            id: title
            text: ""
            size_hint_y: None
            height: 40

        Label:
            id: genre
            text: ""
            size_hint_y: None
            height: 30

        ScrollView:
            Label:
                id: overview
                text: ""
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None

        TextInput:
            id: rating_input
            hint_text: "Rate (0.5–5.0)"
            size_hint_y: None
            height: 40

        Button:
            text: "Add to Library"
            on_press: root.add_movie()

        Button:
            text: "Back"
            on_press: app.root.current = "search"


<LibraryScreen>:
    name: "library"

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Label:
            text: "Your Library"
            size_hint_y: None
            height: 40

        ScrollView:
            Label:
                id: library_list
                text: ""
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None

        Button:
            text: "Back"
            on_press: app.root.current = "search"